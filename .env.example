# Copy to .env for local development (never commit .env)

# --- Application ---
APP_NAME=support-ops-agent
ENVIRONMENT=development
LOG_LEVEL=INFO

# --- OpenAI (required for local env-based secrets) ---
OPENAI_API_KEY=<api-key>
OPENAI_MODEL=gpt-4.1-nano

# --- Secrets loading: env | aws_secrets_manager | auto ---
SECRETS_SOURCE=env

# --- AWS (production-style settings; used when SECRETS_SOURCE includes AWS) ---
AWS_REGION=us-east-1
AWS_SECRETS_MANAGER_SECRET_NAME=support-ops-agent/openai

# --- Logging ---
ENABLE_CLOUDWATCH_LOGGING=true
CLOUDWATCH_LOG_GROUP=/support-ops/agent
CLOUDWATCH_LOG_STREAM_PREFIX=agent

# --- Optional ---
# REDIS_URL=redis://localhost:6379/0
REQUEST_TIMEOUT_SECONDS=120
